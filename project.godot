; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Tales from Ulcantron: Purity Wars"
config/description="Narrative RPG foundation build for Tales from Ulcantron: Purity Wars"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/art/generated/stage_8_5/map_fighter.png"

[autoload]

SignalBus="*res://autoloads/SignalBus.gd"
StatRegistry="*res://autoloads/StatRegistry.gd"
GameClock="*res://autoloads/GameClock.gd"
PlayerData="*res://autoloads/PlayerData.gd"
SceneManager="*res://autoloads/SceneManager.gd"
DialogueManager="*res://autoloads/DialogueManager.gd"
SaveManager="*res://autoloads/SaveManager.gd"
AlignmentSystem="*res://autoloads/AlignmentSystem.gd"
ActorVisuals="*res://autoloads/ActorVisuals.gd"
AudioManager="*res://autoloads/AudioManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="viewport"

